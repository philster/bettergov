{
  "name": "bettergovph",
  "account_id": "{{BETTERGOV_ACCOUNT_ID}}",
  "compatibility_date": "2025-11-17",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
  "kv_namespaces": [
    {
      "id": "{{BETTERGOV_BROWSER_KV_ID}}",
      "binding": "BROWSER_KV",
    },
    {
      "id": "{{BETTERGOV_FOREX_KV_ID}}",
      "binding": "FOREX_KV",
    },
    {
      "id": "{{BETTERGOV_WEATHER_KV_ID}}",
      "binding": "WEATHER_KV",
    },
  ],
}
